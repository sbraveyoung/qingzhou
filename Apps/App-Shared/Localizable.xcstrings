    "VPN 在跑就关、没跑就开。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Turns the VPN off if it's running, on if it's not."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "VPN が動作中ならオフ、そうでなければオンにします。"
          }
        },
        "zh-Hant": {
