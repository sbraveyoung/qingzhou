        }
      }
    },
    "VPN 配置过期了。先在系统设置里把旧 VPN 删掉重试。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The VPN configuration is stale. Delete the old VPN in System Settings and try again."
