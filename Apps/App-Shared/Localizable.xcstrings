    "应用运行时的事件（连接 VPN、刷新订阅、测速、报错等）会记录在这里。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runtime events (connecting the VPN, refreshing subscriptions, speed tests, errors, and so on) are recorded here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "App の実行中のイベント（VPN の接続、サブスクリプションの更新、速度テスト、エラーなど）がここに記録されます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "應用程式執行時的事件（連線 VPN、重新整理訂閱、測速、報錯等）會記錄在這裡。"
          }
        }
      }
    },
    "延迟接近时优先低倍率": {
