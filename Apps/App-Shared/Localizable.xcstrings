    "扩展定时设置失败": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Extension auto-stop update failed"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拡張機能の自動停止の更新に失敗しました"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "擴充功能定時設定失敗"
          }
        }
      }
    },
    "扩展尚未上报 —— 需 VPN 处于开启状态，且隧道扩展为最新版本（更新 App 后要关-开一次 VPN，运行中的旧扩展进程才会换成新代码）。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The extension hasn't reported yet — the VPN must be on and the tunnel extension up to date (after updating the app, toggle the VPN off and on once so the running old extension process is replaced)."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "拡張機能がまだ報告していません —— VPN がオンで、トンネル拡張機能が最新である必要があります（App の更新後、VPN を一度オフ→オンにすると、実行中の古い拡張機能プロセスが新しいコードに置き換わります）。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "擴充功能尚未回報 —— 需 VPN 處於開啟狀態，且隧道擴充功能為最新版本（更新 App 後要關-開一次 VPN，執行中的舊擴充功能程序才會換成新程式碼）。"
          }
        }
      }
    },
