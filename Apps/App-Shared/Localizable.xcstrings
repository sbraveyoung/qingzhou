    "%lld 分 · 权重 %lld%%": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld pts · weight %lld%%"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 点 · 重み %lld%%"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld 分 · 權重 %lld%%"
          }
        }
      }
    },
    "自动择优按此综合评分选节点：延迟 / 稳定性 / 带宽 / 成本四维各归一到 0–100 分再加权求和。每维右侧是它的得分与权重，权重由「设置 → 择优偏好」的档位决定。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Auto-select picks nodes by this overall score: latency, stability, bandwidth, and cost are each normalized to 0–100 and weighted. Each row shows the dimension's score and weight; weights come from the profile in Settings → Selection preference."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "自動選択はこの総合スコアでノードを選びます：遅延 / 安定性 / 帯域幅 / コストの 4 観点をそれぞれ 0〜100 に正規化し、重み付けして合計します。各行の右側はその観点のスコアと重みで、重みは「設定 → 選択の優先設定」のプリセットで決まります。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自動擇優按此綜合評分選節點：延遲 / 穩定性 / 頻寬 / 成本四維各正規化到 0–100 分再加權求和。每維右側是它的得分與權重，權重由「設定 → 擇優偏好」的檔位決定。"
          }
        }
      }
    },
    "暂无评分数据 —— 先给节点测一次速。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No score yet — run a speed test on this node first."
