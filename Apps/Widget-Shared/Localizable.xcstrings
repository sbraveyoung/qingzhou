{
  "sourceLanguage": "zh-Hans",
  "strings": {
    "• Siri：对 Siri 说「开启轻舟」": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Siri: say “Turn on Qingzhou”"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• Siri：Siriに「Qingzhouをオンにして」と話しかける"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "• Siri：對 Siri 說「開啟輕舟」"
          }
        }
      }
    },
    "• 快捷指令：搜「轻舟」，开 / 关 / 切换、状态判断": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Shortcuts: search “Qingzhou” — start / stop / toggle / status check"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• ショートカット：「Qingzhou」を検索 — オン / オフ / 切り替え / 状態確認"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "• 捷徑：搜尋「輕舟」，開 / 關 / 切換、狀態判斷"
          }
        }
      }
    },
    "• 控制中心：添加「轻舟 VPN」控件，一键启停": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Control Center: add the “Qingzhou VPN” control for one-tap toggling"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• コントロールセンター：「Qingzhou VPN」コントロールを追加してワンタップで切り替え"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "• 控制中心：加入「輕舟 VPN」控制項目，一鍵啟停"
          }
        }
      }
    },
    "• 自动化：打开某 App 时自动连接，关闭时断开": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "• Automation: auto-connect when an app opens, disconnect when it closes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "• オートメーション：Appを開くと自動的に接続し、閉じると切断"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "• 自動化：開啟某 App 時自動連線，關閉時中斷"
          }
        }
      }
    },
    "一键启停 VPN。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Toggle the VPN with one tap."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワンタップでVPNを切り替えます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "一鍵啟停 VPN。"
          }
        }
      }
    },
    "切换中…": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switching…"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切り替え中…"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "切換中…"
          }
        }
      }
    },
    "已连接": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Connected"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続済み"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已連線"
          }
        }
      }
    },
    "开 = 连接上次使用的节点，关 = 断开。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On connects to the last used node; off disconnects."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オン＝前回使用したノードに接続、オフ＝切断。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開 = 連線上次使用的節點，關 = 中斷。"
          }
        }
      }
    },
    "开启": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オン"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟"
          }
        }
      }
    },
    "断开": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disconnect"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "切断"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "中斷"
          }
        }
      }
    },
    "更多玩法": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "More to Try"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "その他の使い方"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "更多玩法"
          }
        }
      }
    },
    "未连接": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Not Connected"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "未接続"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "未連線"
          }
        }
      }
    },
    "查看连接状态，一键启停。": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "See connection status and toggle the VPN with one tap."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "接続状態を確認し、ワンタップで切り替えます。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "查看連線狀態，一鍵啟停。"
          }
        }
      }
    },
    "设定轻舟 VPN": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Set Qingzhou VPN"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Qingzhou VPNを設定"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "設定輕舟 VPN"
          }
        }
      }
    },
